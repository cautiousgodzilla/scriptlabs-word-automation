# LLM Provider: anthropic | openai | google
LLM_PROVIDER=anthropic

# Your API key for the chosen provider
LLM_API_KEY=sk-ant-...

# Model name (provider-specific)
# Anthropic examples: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5-20251001
# OpenAI examples:    gpt-4o, gpt-4o-mini, o3
# Google examples:    gemini-2.5-pro, gemini-2.5-flash
LLM_MODEL=claude-sonnet-4-6

# Server port
PORT=3579
